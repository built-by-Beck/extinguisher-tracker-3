# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stripe (publishable key for client-side)
VITE_STRIPE_PUBLISHABLE_KEY=

# Public site URL for marketing meta tags (Open Graph canonical URL). No trailing slash.
# Example: https://yourdomain.com
VITE_PUBLIC_SITE_URL=

# Google AdSense publisher ID (leave empty to disable all ads)
# Example: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_PUB_ID=

# Plan Pricing & Limits (change these, rebuild + deploy = prices update everywhere)
VITE_PRICE_BASIC=39.99
VITE_PRICE_PRO=129.99
VITE_PRICE_ELITE=229.99
VITE_LIMIT_BASIC=50
VITE_LIMIT_PRO=250
VITE_LIMIT_ELITE=500

# Billing / savings (Vite injects at build time)
VITE_TRIAL_DAYS=14
# Set to false and rebuild to remove launch promo from pricing page
VITE_LAUNCH_PROMO_ENABLED=true
VITE_LAUNCH_PROMO_MAX_CUSTOMERS=100
