# Deploy-time parameters (Firebase CLI loads this file — keep secrets OUT of here).
# Put STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET in functions/.env.secret instead
# (see .env.secret.example), then: pnpm run secrets:push
# Emulator: copy those two lines into functions/.secret.local for defineSecret, or use
# firebase functions:secrets:access to pull test secrets.

# Stripe Price IDs (must match Dashboard mode: test keys → test mode price IDs).
# Each price must belong to the matching Product below (the catalog rows with images).
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ELITE=

# Yearly subscription prices (same Products as monthly; recurring yearly).
# Unit amount should match: (monthly USD) × 12 × 0.9  — e.g. Basic $29.99/mo → $323.89/yr.
STRIPE_PRICE_ID_BASIC_YEARLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_ELITE_YEARLY=

# Canonical Stripe Product IDs (Extinguisher Tracker — use for coupon “applies to” / Dashboard)
# Basic:  prod_UAs1TFmyag2GaV
# Pro:    prod_UAsFmD7J7S5blx
# Elite:  prod_UAsbfqtk2lf45j

# Plan Pricing & Limits (change these, redeploy = prices update in webhook + checkout)
PRICE_BASIC=29.99
PRICE_PRO=99
PRICE_ELITE=199
LIMIT_BASIC=50
LIMIT_PRO=250
LIMIT_ELITE=500

# --- Launch coupons (product-scoped; managed via scripts/stripe-setup-launch-promos.sh) ---
# Promotion codes: EX3BASIC50 / EX3PRO50 / EX3ELITE50
# Checkout accepts promotion codes (createCheckoutSession.allow_promotion_codes).
#
# Current live coupon IDs (2026-06-21):
#   Basic:  kUd0UYZ6   → prod_UAs1TFmyag2GaV
#   Pro:    C8UnPLfE   → prod_UAsFmD7J7S5blx
#   Elite:  FSCPXWPQ   → prod_UAsbfqtk2lf45j

STRIPE_TRIAL_DAYS=14
# Pro monthly no-card trial (optional; default 7). Align with STRIPE_TRIAL_DAYS when possible.
PRO_TRIAL_DAYS=14

# Shared launch promo pool size (must match VITE_LAUNCH_PROMO_MAX_CUSTOMERS on frontend)
LAUNCH_PROMO_MAX_CUSTOMERS=100
