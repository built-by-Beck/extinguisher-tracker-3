# Stripe API + webhook signing secrets only. Used by: pnpm run secrets:push
# Do NOT duplicate these in functions/.env — Firebase CLI loads .env as plain env vars
# and that conflicts with Secret Manager (defineSecret) on deploy.
#
# Test mode: use sk_test_... and the Signing secret from Developers → Webhooks with
# "Test mode" enabled. Live whsec will not verify test checkout events.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
